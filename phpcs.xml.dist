<?xml version="1.0"?>
<ruleset name="{{PLUGIN_NAME}}">
    <description>{{PLUGIN_NAME}} coding standards — mirrors the WPFlint framework ruleset.</description>

    <file>app/</file>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="WordPress">
        <!-- Allow PSR-4 file naming (PascalCase class files). -->
        <exclude name="WordPress.Files.FileName"/>
        <!-- Container terminology: $abstract, $concrete are standard IoC names. -->
        <exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames"/>
    </rule>

    <config name="minimum_wp_version" value="5.9"/>
    <config name="testVersion" value="7.4-"/>
</ruleset>
