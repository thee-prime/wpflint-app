{
  "name": "thee-prime/wpflint-app",
  "description": "WPFlint WordPress plugin skeleton — start your plugin with composer create-project thee-prime/wpflint-app my-plugin",
  "type": "project",
  "license": "MIT",
  "keywords": [
    "wordpress",
    "plugin",
    "wpflint",
    "skeleton"
  ],
  "require": {
    "php": ">=7.4",
    "thee-prime/wpflint": "^1.0"
  },
  "require-dev": {
    "brianhenryie/strauss": "^0.19",
    "phpunit/phpunit": "^11.0",
    "brain/monkey": "^2.6",
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "extra": {
    "strauss": {
      "target_directory": "vendor-prefixed",
      "namespace_prefix": "App\\",
      "classmap_prefix": "App_",
      "packages": [
        "thee-prime/wpflint"
      ],
      "delete_vendor_packages": false
    }
  },
  "scripts": {
    "post-create-project-cmd": [
      "@php install.php"
    ],
    "post-install-cmd": [],
    "post-update-cmd": [],
    "strauss": [
      "@php vendor/bin/strauss"
    ],
    "test": [
      "@php vendor/bin/phpunit --colors=always"
    ],
    "lint": [
      "@php vendor/bin/phpcs"
    ],
    "lint:fix": [
      "@php vendor/bin/phpcbf"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "brianhenryie/strauss": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "audit": {
      "ignore": [
        "PKSA-5jz8-6tcw-pbk4",
        "PKSA-z3gr-8qht-p93v"
      ]
    }
  }
}
